# Copy this file to .env and fill your real Supabase connection.
# Option 1 (recommended): full connection URL in a single line.
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-0-xxx.pooler.supabase.com:5432/postgres

# Option 2: split into separate values (script will assemble conninfo).
# user=postgres.<project-ref>
# password=<your-password>
# host=aws-0-xxx.pooler.supabase.com
# port=5432
# dbname=postgres

# Optional aliases supported by migrate_to_supabase.py
SUPABASE_URL=
SUPABSE_URL=