CREATE TABLE Nganh_Hoc (
    id INT PRIMARY KEY,
    ten_nganh VARCHAR(255) NOT NULL,
    ma_nganh VARCHAR(50),
    ma_tuyen_sinh VARCHAR(50)
);

-- Tạo bảng phụ: CHƯƠNG TRÌNH ĐÀO TẠO (Quan hệ 1-N với bảng Nganh_Hoc)
CREATE TABLE Chuong_Trinh_Dao_Tao (
    id INT PRIMARY KEY,
    nganh_id INT,
    ten_chuong_trinh VARCHAR(255) NOT NULL,
    nam_hoc VARCHAR(50),
    ma_chuong_trinh VARCHAR(50),
    FOREIGN KEY (nganh_id) REFERENCES Nganh_Hoc(id)
);</sql><current_tab id="0"/></tab_sql></sqlb_project>
